# Copy this file to .env and fill in your values.
# cp .env.example .env

# =============================================================================
# Environment selector  ← ONLY LINE YOU NEED TO CHANGE when switching
# =============================================================================
#   development  →  local Docker Kafka  (kafka:29092, no SSL)
#   production   →  Aiven cloud Kafka   (aivencloud.com, SSL)
KAFKA_ENV=development

# =============================================================================
# Production — Aiven Kafka
# =============================================================================
# Uncomment and fill in when KAFKA_ENV=production.
#
# KAFKA_BOOTSTRAP_SERVERS=kafka-xxxxxxxx-your-project.j.aivencloud.com:12345
# KAFKA_SSL_CAFILE=./certs/ca.pem
# KAFKA_SSL_CERTFILE=./certs/service.cert
# KAFKA_SSL_KEYFILE=./certs/service.key
# REPLICATION_FACTOR=2   # Aiven cluster has 2 registered brokers — RF must be ≤ 2

# =============================================================================
# Trading pipeline
# =============================================================================
SOURCE=binance
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
